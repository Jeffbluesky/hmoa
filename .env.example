# ==========================================
# 数据库配置
# 默认使用 MySQL（与生产环境保持一致）。
# 若本地想临时使用 SQLite，可改为：DATABASE_URL="file:./dev.db"
# 并且执行 pnpm db:use:sqlite 切换 Prisma provider 为 sqlite。
# ==========================================
DATABASE_URL="mysql://hmoa:hmoa123@localhost:3306/hmoa"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
COOKIE_DOMAIN="localhost"

# 文件存储（当前仅支持本地存储）
STORAGE_TYPE="local"
UPLOAD_DIR="uploads"

# 服务端端口
PORT=3001
NODE_ENV="development"
